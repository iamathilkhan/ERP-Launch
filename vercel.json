{
    "buildCommand": "git config remote.origin.url https://github.com/iamathilkhan/ERP-Launch.git && git lfs pull && npm run build",
    "headers": [
        {
            "source": "/(.*)\\.webm",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "video/webm"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}